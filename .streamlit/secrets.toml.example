# Copy this to secrets.toml and fill in your values
# DO NOT commit secrets.toml to git!

password = "your_dashboard_password"

[sevenrooms]
client_id = "your_client_id"
client_secret = "your_client_secret"

[eviivo]
client_id = "your_client_id"
client_secret = "your_client_secret"
# Test environment (QA):
# auth_url = "https://qaext-auth.eviivo.com/api/connect/token"
# api_url = "https://qaext-io.eviivo.com/pms/v2"
# Production environment:
auth_url = "https://auth.eviivo.com/api/connect/token"
api_url = "https://io.eviivo.com/pms/v2"
